# Example environment for the local live demo (deploy/vps). Copy to demo.env, or
# let deploy/vps/install.sh derive and write it. The real demo.env is git-ignored
# (INV-1); only this placeholder is tracked, exactly like the *.tfvars.example
# files under infra/.
#
# Read both by systemd (EnvironmentFile) and by the demo shell scripts, so every
# line must stay plain KEY=VALUE: no shell expansion, no command substitution.

# Public host the demo answers on. install.sh derives it at deploy time from the
# box public IPv4 (curl -4) as climate-index dot <the IPv4 with dots replaced by
# dashes> dot sslip.io, and writes the result here. Empty in the tracked
# placeholder so no host-specific literal is ever committed.
CII_DEMO_HOST=

# Optional: the service install.sh asks for the box public IPv4 (curl -4). Left
# empty so no endpoint literal is tracked; with none set the address is read from
# the box's own default route instead, which needs no network call at all.
CII_DEMO_IP_LOOKUP_URL=

# Loopback port the always-on dashboard binds. Caddy is the only public door; the
# dashboard itself never binds a routable address.
CII_DEMO_PORT=8501

# Where the served snapshot and the refresh staging area live. A plain filesystem
# path, neither an endpoint nor a secret.
CII_DEMO_DATA_DIR=/var/lib/climate-index-demo

# The single cadence value: how long after one refresh completes the next fires.
# Any systemd time span (30min, 15min, 1h). Change it here and re-run install.sh.
CII_DEMO_REFRESH_INTERVAL=30min

# Which event source the demo feeds from. "real" fetches genuine readings from
# Open-Meteo; "simulated" uses the committed generators (ADR-0007).
CII_SOURCE_BACKEND=real

# Real source endpoints. Only read when CII_SOURCE_BACKEND=real. Public
# documented endpoints, kept out of source code like every other endpoint
# (INV-1); this file is git-ignored and only its placeholder is tracked.
CII_OPEN_METEO_WEATHER_URL=https://api.open-meteo.com/v1/forecast
CII_OPEN_METEO_AIR_QUALITY_URL=https://air-quality-api.open-meteo.com/v1/air-quality

# Real mode window size. The readings are hourly, so hourly windows keep every
# window populated; at the 30 minute default every other window would be empty.
# Demo-only: the repository default stays 30 and no test depends on this.
CII_WINDOW_MINUTES=60

# Real mode: how many past days of hourly readings each refresh republishes.
# Republishing hours already published is intentional. The aggregate write is
# idempotent on the natural key, so a repeated hour lands on the same row rather
# than duplicating it, which is the FR-6 / NFR-R1 property under continuous
# exercise by the live demo.
CII_DEMO_PAST_DAYS=1

# Bounded regeneration size, SIMULATED MODE ONLY. Each refresh rebuilds this many
# event-time windows of history per region, with this many events per stream type
# per region per window. Bounded input plus a wiped staging area is what keeps the
# snapshot self-contained and the disk footprint flat across refreshes.
CII_DEMO_WINDOWS=12
CII_DEMO_EVENTS_PER_WINDOW=2

# Share of those windows given thinner coverage (weather readings only, and a
# single reading in the oldest of them), SIMULATED MODE ONLY. A generated feed
# cannot produce a real gap, so the demo has to arrange one for the confidence
# mechanism to be visible. In real mode this is not applied at all: the provider's
# own gaps are the signal, and nothing artificially degrades or upgrades anything.
# Input only either way: no grade is ever set anywhere.
CII_DEMO_DEGRADED_WINDOW_FRACTION=0.25

# Compose project name for the refresh stack. Distinct from any other project on
# the box, so bringing the refresh down never touches another stack's containers
# or volumes.
CII_DEMO_COMPOSE_PROJECT=cii-demo
