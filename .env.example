# Example environment for climate_index. Copy to .env and adjust locally.
# This file is the ONLY place example connection/endpoint values appear
# (INV-1). Everything below is read by src/climate_index/config.py.

# E-1 region set (comma-separated). Adding a region is config-only (NFR-S1).
CII_REGIONS=EUR,NAM,AFR,ASI

# E-7 per-region temperature normal baselines, degrees Celsius (JSON).
CII_REGION_BASELINES={"EUR": 12.0, "NAM": 14.0, "AFR": 24.0, "ASI": 20.0}

# E-7 index component weights (JSON).
CII_INDEX_WEIGHTS={"temperature_anomaly": 0.4, "dryness_index": 0.3, "pollution_index": 0.3}

# E-7 / FR-9 verbal-label band boundaries on the 0..100 index (JSON).
CII_LABEL_THRESHOLDS={"low_max": 33.34, "medium_max": 66.67}

# FR-5 event-time tumbling window size, minutes.
CII_WINDOW_MINUTES=30

# NFR-O1 log level.
CII_LOG_LEVEL=INFO

# UC-5 display framing for the read-only dashboard. The page states no
# definition of its own; it renders these. Scale and direction come from spec
# E-5 and E-7, the tier glosses from NFR-DQ2.
CII_INDEX_SUMMARY=The Climate Impact Index scores each region from 0 to 100 by combining a temperature anomaly, a dryness index, and a pollution index. Higher means greater simulated climate impact.
CII_INDEX_AXIS_LABEL=Impact index (0 to 100)
CII_SIMULATED_FEED_NOTICE=The feed is simulated: weather and satellite readings are generated by the producer, not collected from real world observations.
CII_CONFIDENCE_TIER_GLOSSES={"MEASURED": "both stream types present in the window", "INFERRED": "one stream type only, so a component is imputed", "AMBIGUOUS": "fewer validated events than the sparsity threshold"}
CII_PIPELINE_SUMMARY=Simulated sources publish to Kafka, a deterministic gate validates or quarantines each event, the processor buckets events into event-time windows and computes the index with its confidence grade, and this page reads the published snapshot read-only.

# Public source repository the dashboard links to. A documentation pointer, not
# a service endpoint: nothing connects to it.
CII_SOURCE_REPOSITORY_URL=https://github.com/rkendev/real-time-climate-impact-index

# Live demo knobs the dashboard and the demo feeder read. The cadence is a
# systemd time span and is also set in deploy/vps/demo.env; the fraction is the
# share of backfilled windows given sparser coverage so the confidence grade the
# pipeline computes drops below the top tier on some of them.
CII_DEMO_REFRESH_INTERVAL=30min
CII_DEMO_DEGRADED_WINDOW_FRACTION=0.25

# Transport endpoint. Local single-node Kafka example; populated per environment.
# Kept out of source code (INV-1); set here or in the real .env only.
CII_TRANSPORT_BOOTSTRAP_SERVERS=localhost:9092

# Local store locations (filesystem paths, not endpoints or secrets).
CII_RAW_STORE_PATH=data/raw
CII_AGGREGATE_STORE_PATH=data/aggregates.duckdb

# Aggregate-store backend the composition root builds: "duckdb" (local, default)
# or "aws" (S3 Iceberg aggregate-of-record fanned out to DynamoDB).
CII_AGGREGATE_BACKEND=duckdb

# Phase 2 AWS connection details (ADR-0003). Kept out of source (INV-1); set here
# or in the real .env only. The endpoint override is empty in production (real
# AWS); the test fixture points it at a local moto server.
CII_AWS_REGION=us-east-1
CII_AWS_ENDPOINT_URL=

# S3 Iceberg aggregate-of-record: warehouse bucket, namespace, table, and the
# catalog properties (JSON). Example below is the Glue catalog on AWS; the test
# fixture substitutes the pyiceberg SQL (SQLite) catalog properties.
CII_ICEBERG_WAREHOUSE_BUCKET=cii-aggregate-of-record
CII_ICEBERG_NAMESPACE=climate_index
CII_ICEBERG_TABLE=climate_index
CII_ICEBERG_CATALOG_PROPERTIES={"type": "glue"}

# DynamoDB serving store table name.
CII_DYNAMO_TABLE=cii-serving

# S3 raw store bucket and key prefix (append-only audit trail, FR-7).
CII_RAW_S3_BUCKET=cii-raw
CII_RAW_S3_PREFIX=raw
