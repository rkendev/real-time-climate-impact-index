# Virtual environment
.venv/

# Local environment and secrets (never committed; INV-1)
.env

# Local data and the smoke marker (produced by later tracks)
data/
.smoke_ok

# Terraform working dirs, state, and real tfvars (never committed; INV-1, ADR-0005).
