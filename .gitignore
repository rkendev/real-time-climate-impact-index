# Virtual environment
.venv/

# Local environment and secrets (never committed; INV-1)
.env

# Local data and the smoke marker (produced by later tracks)
data/
.smoke_ok

# Terraform working dirs, state, and real tfvars (never committed; INV-1, ADR-0005).
# The *.tfvars.example files are committed placeholders; real *.tfvars are not.
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
infra/**/*.tfvars
infra/**/zz_local_backend_override.tf

# The real demo environment for the local live demo (never committed; INV-1).
# Only the *.env.example placeholder is tracked, the same split as the tfvars.
deploy/vps/*.env
!deploy/vps/*.env.example

# Python caches and tool state
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
